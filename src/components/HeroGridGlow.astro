---
// Cursor-reactive grid glow — the hero's blueprint lines light up purple
// around a moving pointer, scaled by speed, decaying to nothing at rest.
// Pointer-fine devices only; disabled under prefers-reduced-motion.
---

<canvas class="grid-glow" aria-hidden="true"></canvas>

<style>
  .grid-glow {
    position: absolute;
    inset: 0;
    /* explicit CSS size — a replaced element would otherwise render at its
       buffer size (hero × devicePixelRatio) and drift off the cursor */
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 0;
  }
</style>

<script>
  const canvas = document.querySelector<HTMLCanvasElement>(".grid-glow");
  const hero = canvas?.parentElement;

  const motionOk = !matchMedia("(prefers-reduced-motion: reduce)").matches;
  const pointerFine = matchMedia("(pointer: fine)").matches;

  if (canvas && hero && motionOk && pointerFine) {
    const ctx = canvas.getContext("2d")!;
    const styles = getComputedStyle(document.documentElement);
    const CELL = parseFloat(styles.getPropertyValue("--grid-cell")) || 48;
    const BLOCK = 8; // pixel-block length along a line
    const STEPS = 5; // quantized alpha levels — the "pixelated fade"

    // accent → link ramp, alpha baked per step (step 1 faint … STEPS hot)
    const hex = (name: string) => {
      const h = styles.getPropertyValue(name).trim();
      return [1, 3, 5].map((i) => parseInt(h.slice(i, i + 2), 16));
    };
    const lo = hex("--accent");
    const hi = hex("--link");
    const stepFill: string[] = [];
    for (let s = 1; s <= STEPS; s++) {
      const t = (s - 1) / (STEPS - 1);
      /* even the faintest step carries some link brightness — pure
         --accent is near-invisible on the page background */
      const m = 0.3 + 0.7 * t;
      const mix = lo.map((c, i) => Math.round(c + (hi[i] - c) * m));
      stepFill[s] = `rgba(${mix[0]},${mix[1]},${mix[2]},${(0.45 + 0.55 * t).toFixed(2)})`;
    }

    let w = 0;
    let h = 0;
    const resize = () => {
      const dpr = window.devicePixelRatio || 1;
      w = hero.clientWidth;
      h = hero.clientHeight;
      canvas.width = Math.round(w * dpr);
      canvas.height = Math.round(h * dpr);
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    };
    new ResizeObserver(resize).observe(hero);
    resize();

    // energy model: pointer speed charges it, time drains it
    let energy = 0;
    let cx = -1e4;
    let cy = -1e4;
    let docX = 0; // hero offset in document coords — grid phase source
    let docY = 0;
    let lastX = 0;
    let lastY = 0;
    let lastT = 0;
    let running = false;
    let lastFrame = 0;

    // deterministic per-block jitter so step edges dither, not ring
    const dither = (i: number, j: number) => {
      let n = (i * 374761393 + j * 668265263) | 0;
      n = ((n ^ (n >> 13)) * 1274126177) | 0;
      return ((n >>> 0) / 4294967295 - 0.5) * 0.9;
    };

    const frame = (now: number) => {
      const dt = Math.min(64, now - lastFrame);
      lastFrame = now;
      energy *= Math.exp(-dt / 400);

      ctx.clearRect(0, 0, w, h);
      if (energy < 0.02) {
        running = false;
        return;
      }

      const R = 60 + 130 * energy;
      const phaseX = ((docX % CELL) + CELL) % CELL;
      const phaseY = ((docY % CELL) + CELL) % CELL;

      // vertical lines: canvas x where (x + phaseX) is a multiple of CELL
      for (let x = -phaseX; x <= w; x += CELL) {
        if (x < 0) continue;
        const dx = x - cx;
        if (Math.abs(dx) > R) continue;
        const jMin = Math.floor((cy - R + docY) / BLOCK);
        const jMax = Math.ceil((cy + R + docY) / BLOCK);
        const i = Math.round((x + docX) / CELL);
        for (let j = jMin; j <= jMax; j++) {
          const y = j * BLOCK - docY;
          const d = Math.hypot(dx, y + BLOCK / 2 - cy);
          if (d > R) continue;
          const a = energy * Math.pow(1 - d / R, 1.5);
          const s = Math.floor(a * STEPS + dither(i, j) + 0.5);
          if (s < 1) continue;
          const thick = s >= STEPS - 1 ? 3 : s >= 2 ? 2 : 1;
          ctx.fillStyle = stepFill[Math.min(s, STEPS)];
          ctx.fillRect(x - (thick - 1) / 2, y, thick, BLOCK - 1);
        }
      }
      // horizontal lines
      for (let y = -phaseY; y <= h; y += CELL) {
        if (y < 0) continue;
        const dy = y - cy;
        if (Math.abs(dy) > R) continue;
        const iMin = Math.floor((cx - R + docX) / BLOCK);
        const iMax = Math.ceil((cx + R + docX) / BLOCK);
        const j = Math.round((y + docY) / CELL);
        for (let i = iMin; i <= iMax; i++) {
          const x = i * BLOCK - docX;
          const d = Math.hypot(x + BLOCK / 2 - cx, dy);
          if (d > R) continue;
          const a = energy * Math.pow(1 - d / R, 1.5);
          const s = Math.floor(a * STEPS + dither(j, i) + 0.5);
          if (s < 1) continue;
          const thick = s >= STEPS - 1 ? 3 : s >= 2 ? 2 : 1;
          ctx.fillStyle = stepFill[Math.min(s, STEPS)];
          ctx.fillRect(x, y - (thick - 1) / 2, BLOCK - 1, thick);
        }
      }

      requestAnimationFrame(frame);
    };

    hero.addEventListener("pointermove", (e) => {
      const rect = hero.getBoundingClientRect();
      docX = rect.left + window.scrollX;
      docY = rect.top + window.scrollY;
      cx = e.clientX - rect.left;
      cy = e.clientY - rect.top;

      const now = performance.now();
      if (lastT > 0) {
        const dt = Math.max(1, now - lastT);
        const speed = Math.hypot(e.clientX - lastX, e.clientY - lastY) / dt;
        energy = Math.max(energy, Math.min(1, speed / 2.5));
      }
      lastX = e.clientX;
      lastY = e.clientY;
      lastT = now;

      if (!running && energy >= 0.02) {
        running = true;
        lastFrame = now;
        requestAnimationFrame(frame);
      }
    });
  }
</script>
