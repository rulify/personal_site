---
import { SITE } from "../consts";
---

<footer class="site-footer">
  <div class="hazard-strip" aria-hidden="true"></div>
  <div class="container footer-inner">
    <p class="value-s ident">{SITE.ident} © {SITE.year}</p>
    <nav id="site-nav" aria-label="Footer">
      <ul class="footer-nav" role="list">
        <li><a class="label-xs" href="/">HOME</a></li>
        <li><a class="label-xs" href="/posts">POSTS</a></li>
        <li><a class="label-xs" href="/projects">PROJECTS</a></li>
        <li><a class="label-xs" href="/about">ABOUT</a></li>
      </ul>
    </nav>
    <a class="value-s source" href={SITE.repo}>SOURCE</a>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--border);
    margin-top: var(--sp-8);
  }
  .footer-inner {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--sp-4);
    padding-top: var(--sp-6);
    padding-bottom: var(--sp-6);
  }
  .ident {
    color: var(--text-muted);
    margin: 0;
  }
  .footer-nav {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-4);
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .footer-nav a,
  .source {
    color: var(--text-muted);
    text-decoration: none;
    transition: color var(--transition);
  }
  .footer-nav a:hover,
  .footer-nav a:focus-visible,
  .source:hover,
  .source:focus-visible {
    color: var(--text);
  }
  @media (pointer: coarse) {
    .footer-nav a {
      display: inline-flex;
      align-items: center;
      min-height: 44px;
    }
  }
</style>
