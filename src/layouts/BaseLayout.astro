---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import CommandPalette from "../components/CommandPalette.astro";
import { SITE } from "../consts";

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
const fullTitle = title === SITE.ident ? title : `${title} — ${SITE.ident}`;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    {description && <meta name="description" content={description} />}
    <link
      rel="preload"
      href="/fonts/ibm-plex-sans-latin-400.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/ibm-plex-mono-latin-500.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/ibm-plex-mono-latin-700.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <title>{fullTitle}</title>
  </head>
  <body>
    <a class="skip-link label-xs" href="#main">SKIP TO CONTENT</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <CommandPalette />
  </body>
</html>

<style>
  /* §11: first tab stop, hidden until focused, styled as a mono module */
  .skip-link {
    position: fixed;
    top: var(--sp-2);
    left: var(--sp-2);
    z-index: 20;
    background: var(--surface-raised);
    border: 1px solid var(--border-active);
    border-radius: var(--radius-s);
    padding: var(--sp-2) var(--sp-3);
    color: var(--text);
    text-decoration: none;
  }
  .skip-link:not(:focus) {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip-path: inset(50%);
    white-space: nowrap;
  }
</style>
