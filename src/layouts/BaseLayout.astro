---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { SITE } from "../consts";

interface Props {
  /* omit title on the homepage and set home instead */
  title?: string;
  description?: string;
  home?: boolean;
  ogType?: "website" | "article";
  publishedTime?: string;
  noindex?: boolean;
}

const {
  title,
  description = SITE.description,
  home = false,
  ogType = "website",
  publishedTime,
  noindex = false,
} = Astro.props;

// Person-first titles: the alias stays visual, search results lead with the name
const fullTitle = home
  ? `${SITE.fullName} - ${SITE.headline}`
  : `${title} - ${SITE.fullName}`;

const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL("/og.png", Astro.site);

const personLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: SITE.fullName,
  url: Astro.site?.toString(),
  jobTitle: "Cybersecurity student",
  affiliation: {
    "@type": "CollegeOrUniversity",
    name: "Oxford Brookes University",
  },
  sameAs: [SITE.linkedin, "https://github.com/rulify"],
};
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    {/* ?v busts sticky favicon caches — bump when the mark changes */}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=3" />
    <link rel="icon" href="/favicon.ico?v=3" sizes="32x32" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png?v=3" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="author" content={SITE.fullName} />
    <meta name="theme-color" content="#080b0f" />
    {noindex ? <meta name="robots" content="noindex" /> : <link rel="canonical" href={canonical} />}

    <meta property="og:site_name" content={SITE.fullName} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={`${SITE.fullName} — ${SITE.headline}`} />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    {home && <script type="application/ld+json" set:html={JSON.stringify(personLd)} />}
    <link
      rel="preload"
      href="/fonts/ibm-plex-sans-latin-400.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/ibm-plex-mono-latin-500.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/ibm-plex-mono-latin-700.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <title>{fullTitle}</title>
  </head>
  <body>
    <a class="skip-link label-xs" href="#main">SKIP TO CONTENT</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
  </body>
</html>

<style>
  /* §11: first tab stop, hidden until focused, styled as a mono module */
  .skip-link {
    position: fixed;
    top: var(--sp-2);
    left: var(--sp-2);
    z-index: 20;
    background: var(--surface-raised);
    border: 1px solid var(--border-active);
    border-radius: var(--radius-s);
    padding: var(--sp-2) var(--sp-3);
    color: var(--text);
    text-decoration: none;
  }
  .skip-link:not(:focus) {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip-path: inset(50%);
    white-space: nowrap;
  }
</style>
