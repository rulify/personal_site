---
import BaseLayout from "./BaseLayout.astro";
import "../styles/prose.css";

interface Props {
  title: string;
  description?: string;
  category: string;
  date: string;
  /* read time for posts, status for projects (§8) */
  stat: string;
  /* set only when stat is a genuine status — colours it with a hazard token (§3) */
  statTone?: "ok" | "warn" | "error";
  tags?: string[];
  prev?: { title: string; href: string };
  next?: { title: string; href: string };
}

const {
  title,
  description,
  category,
  date,
  stat,
  statTone,
  tags = [],
  prev,
  next,
} = Astro.props;
---

<BaseLayout
  title={title}
  description={description}
  ogType="article"
  publishedTime={date}
>
  <div class="container">
    <article>
      <header class="article-header">
        <p class="label-xs eyebrow">{category}</p>
        <h1>{title}</h1>
        <div class="article-meta value-s">
          {date} · <span class:list={["stat", statTone]}>{stat}</span> · {
            tags.map((t) => t.toUpperCase()).join(" ")
          }
        </div>
      </header>

      <div class="prose">
        <slot />
      </div>

      <footer class="article-end">
        {
          tags.length > 0 && (
            <ul class="tag-row" role="list">
              {tags.map((t) => (
                <li>
                  <a class="tag label-xs" href="#">
                    {t}
                  </a>
                </li>
              ))}
            </ul>
          )
        }
        {
          (prev || next) && (
            <nav class="pager" aria-label="Adjacent posts">
              {prev ? (
                <a class="pager-card" href={prev.href}>
                  <span class="label-xs pager-label">← PREV</span>
                  <span class="pager-title">{prev.title}</span>
                </a>
              ) : (
                <span />
              )}
              {next && (
                <a class="pager-card pager-next" href={next.href}>
                  <span class="label-xs pager-label">NEXT →</span>
                  <span class="pager-title">{next.title}</span>
                </a>
              )}
            </nav>
          )
        }
      </footer>
    </article>
  </div>
</BaseLayout>

<style>
  .article-header {
    max-width: var(--measure);
    margin: var(--sp-7) auto var(--sp-6);
  }
  .eyebrow {
    color: var(--text-muted);
    margin: 0 0 var(--sp-3);
  }
  .article-header h1 {
    margin-bottom: var(--sp-3);
  }
  .article-meta {
    font-family: var(--font-mono);
    color: var(--text-muted);
  }
  .stat.ok {
    color: var(--ok-text);
  }
  .stat.warn {
    color: var(--warn);
  }
  .stat.error {
    color: var(--error-text);
  }

  /* Motif slot 1: corner ticks on the meta strip, dropped below 768px (§6, §9.4) */
  @media (min-width: 768px) {
    .article-meta {
      position: relative;
      display: inline-block;
      padding: var(--sp-2) var(--sp-3);
    }
    .article-meta::before,
    .article-meta::after {
      content: "";
      position: absolute;
      width: 10px;
      height: 10px;
      border: 1px solid var(--border-active);
    }
    .article-meta::before {
      top: 0;
      left: 0;
      border-right: 0;
      border-bottom: 0;
    }
    .article-meta::after {
      bottom: 0;
      right: 0;
      border-left: 0;
      border-top: 0;
    }
  }

  .article-end {
    max-width: var(--measure);
    margin: var(--sp-7) auto var(--sp-8);
  }

  /* Tag chips (§9.6) */
  .tag-row {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
    margin: 0 0 var(--sp-6);
    padding: 0;
  }
  .tag {
    display: inline-block;
    color: var(--text-muted);
    border: 1px solid var(--border);
    border-radius: var(--radius-s);
    padding: 3px 8px;
    text-decoration: none;
    transition:
      color var(--transition),
      border-color var(--transition);
  }
  .tag:hover,
  .tag:focus-visible {
    color: var(--text);
    border-color: var(--border-active);
  }
  @media (pointer: coarse) {
    .tag {
      display: inline-flex;
      align-items: center;
      min-height: 44px;
    }
  }

  /* Prev/next compact cards (§9.4 end matter) */
  .pager {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--sp-4);
  }
  @media (min-width: 640px) {
    .pager {
      grid-template-columns: 1fr 1fr;
    }
  }
  .pager-card {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-m);
    padding: var(--sp-4);
    text-decoration: none;
    color: var(--text);
    transition:
      background var(--transition),
      border-color var(--transition);
  }
  .pager-card:hover,
  .pager-card:focus-visible {
    background: var(--surface-hover);
    border-color: var(--border-active);
    color: var(--text);
  }
  .pager-label {
    color: var(--text-muted);
  }
  .pager-title {
    font: 500 var(--fs-title-m) / 1.35 var(--font-sans);
  }
  .pager-next {
    text-align: right;
  }
</style>
