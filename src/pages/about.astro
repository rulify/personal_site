---
import BaseLayout from "../layouts/BaseLayout.astro";
import Kicker from "../components/Kicker.astro";
import { SITE } from "../consts";

const linkedinLabel = SITE.linkedin
  .replace(/^https:\/\/www\./, "")
  .replace(/\/$/, "");
---

<BaseLayout
  title="About"
  description="Incoming cybersecurity student at Oxford Brookes. A running log of things taken apart or put together."
>
  <div class="container">
    <article class="measure about">
      <p class="label-xs kicker">
        <span class="chevrons" aria-hidden="true">›››</span> ABOUT
      </p>
      <div class="title-row">
        <h1 class="display-mono">ABOUT</h1>
        <span class="hazard-strip title-rule decal-md" aria-hidden="true"></span>
      </div>
      <div class="prose-body body-m">
        <p>Hi, I'm Jacob.</p>
        <p>
          I'm an incoming cybersecurity student. There wasn't one big moment that
          pulled me in; it's more that everything in tech feels like a puzzle
          to me: a black box sitting there, daring you to open it up and poke
          around, whether or not you were supposed to.
        </p>
        <p>
          That instinct is basically what this site is. I'm starting a
          cybersecurity course at Oxford Brookes University in September, and
          in the meantime this is where I keep the habit going: <a
            href="https://en.wikipedia.org/wiki/Capture_the_flag_(cybersecurity)"
          >CTF</a> boxes I've worked through, and whatever I end up building, mostly
          software but possibly hardware down the line. Less a portfolio,
          more a running log of things I've taken apart or put together.
        </p>
      </div>

      <section id="contact" class="contact" aria-label="Contact">
        <Kicker label="CONTACT" />
        <dl class="contact-list">
          <div class="contact-row">
            <dt class="label-xs">EMAIL</dt>
            <dd><a class="value-s" href={`mailto:${SITE.email}`}>{SITE.email}</a></dd>
          </div>
          <div class="contact-row">
            <dt class="label-xs">LINKEDIN</dt>
            <dd><a class="value-s" href={SITE.linkedin}>{linkedinLabel}</a></dd>
          </div>
        </dl>
      </section>
    </article>
  </div>
</BaseLayout>

<style>
  .about {
    margin-top: var(--sp-7);
    margin-bottom: var(--sp-8);
  }
  .kicker {
    color: var(--text-muted);
    margin: 0 0 var(--sp-3);
  }
  .chevrons {
    color: var(--link);
    letter-spacing: 0.1em;
  }
  .title-row {
    display: flex;
    align-items: baseline;
    gap: var(--sp-4);
    margin-bottom: var(--sp-5);
  }
  .title-rule {
    flex: 1;
  }
  .contact {
    margin-top: var(--sp-7);
  }
  .contact-list {
    margin: 0;
  }
  .contact-row {
    display: flex;
    align-items: baseline;
    gap: var(--sp-4);
    padding: var(--sp-3) 0;
    border-bottom: 1px solid var(--border);
  }
  .contact-row dt {
    color: var(--text-muted);
    min-width: 96px;
  }
  .contact-row dd {
    margin: 0;
  }
  /* very narrow phones: the mono email can't fit beside its label */
  @media (max-width: 379px) {
    .contact-row {
      flex-direction: column;
      gap: var(--sp-1);
    }
  }
  @media (pointer: coarse) {
    .contact-row a {
      display: inline-flex;
      align-items: center;
      min-height: 44px;
    }
  }
</style>
