---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="SITE_IDENT" description="Blogs and internet playground experiments.">
  <main class="container">
    <article class="measure">
      <p class="label-xs" style="color: var(--text-muted); margin-bottom: var(--sp-3);">
        SITE_IDENT / TOKENS
      </p>
      <h1>Tokens and base styles</h1>
      <p class="value-s" style="color: var(--text-muted); margin: var(--sp-2) 0 var(--sp-5);">
        2026-07-03 · build order step 1
      </p>
      <p class="body-m">
        Color, typography, spacing, and layout tokens from the design system are
        live. This page exercises the base document styles: prose at
        <code>body-m</code>, a <a href="/">link in purple</a>, and mono
        metadata above.
      </p>
      <p class="body-m">
        Step 2 preview: <a href="/posts/sample-writeup">the sample writeup page</a>.
      </p>
    </article>
  </main>
</BaseLayout>
