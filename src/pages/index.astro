---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import Card from "../components/Card.astro";
import HeroGridGlow from "../components/HeroGridGlow.astro";
import Kicker from "../components/Kicker.astro";
import { SITE, STATUS_TONE } from "../consts";

const posts = (await getCollection("posts")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
const projects = (await getCollection("projects")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

const fmt = (d: Date) => d.toISOString().slice(0, 10);
const tagStr = (tags: string[]) =>
  tags.slice(0, 3).map((t) => t.toUpperCase()).join(" ");
---

<BaseLayout home description={SITE.description}>
  {/* §10 boot sequence — inline and early so the overlay is up before the
      homepage paints; content renders underneath regardless. */}
  <script is:inline>
    (() => {
      let seen;
      try {
        seen = localStorage.getItem("boot_seen");
      } catch {
        return;
      }
      if (seen || matchMedia("(prefers-reduced-motion: reduce)").matches)
        return;
      // written at animation start: a skip or mid-boot refresh still counts
      try {
        localStorage.setItem("boot_seen", "1");
      } catch {}

      const style = document.createElement("style");
      style.textContent =
        "#boot{position:fixed;inset:0;z-index:100;background:var(--bg);display:grid;place-items:center;transition:opacity 250ms ease-out}" +
        "#boot.out{opacity:0}" +
        "#boot.fast{transition-duration:150ms}" +
        "#boot .blk{max-width:480px;font:400 13px/1.7 var(--font-mono);color:var(--text)}" +
        "#boot pre{margin:0 0 1.7em;font:inherit;color:var(--text);opacity:0;transition:opacity 120ms ease-out}" +
        "#boot pre.in{opacity:1}" +
        "#boot .bl{visibility:hidden;white-space:pre;min-height:1.7em}" +
        "#boot .bl.in{visibility:visible}" +
        "#boot .bm{color:var(--text-muted)}" +
        "#boot .bok{color:var(--ok-text)}" +
        "#boot .cur{display:inline-block;width:.55em;height:1em;margin-left:1px;vertical-align:-2px;background:var(--text);animation:bblink 800ms steps(1) infinite}" +
        "@keyframes bblink{50%{opacity:0}}" +
        "#boot .bskip{position:absolute;bottom:24px;left:0;right:0;text-align:center;font:500 var(--fs-label-xs)/1 var(--font-mono);letter-spacing:var(--track-label);color:var(--text-disabled)}";

      const CHECKS = [
        ["CORE PWR", " OK "],
        ["NEURAL LINK", " OK "],
        ["THRM REGULATION", " OK "],
        ["SERVO CALIBRATION", " OK "],
        ["GYRO STABILISATION", " OK "],
        ["AUX SENSOR ARRAY", " OK "],
        ["PILOT VITALS", " OK "],
        ["INTRUSION CM", "ARMD"],
        ["WEAPONS SYS", "SAFE"],
      ];

      const overlay = document.createElement("div");
      overlay.id = "boot";
      overlay.setAttribute("aria-hidden", "true");
      const blk = document.createElement("div");
      blk.className = "blk";

      const ident = document.createElement("pre");
      ident.textContent =
        "  ___ _    _____   __    __  _ \n" +
        " | _ \\ |  | __\\ \\ / /__ /  \\/ |\n" +
        " |   / |__| _| \\ V /___| () | |\n" +
        " |_|_\\____|_|   |_|     \\__/|_|";
      blk.appendChild(ident);

      const lineEls = [];
      const addLine = (build) => {
        const el = document.createElement("div");
        el.className = "bl";
        if (build) {
          build(el);
          lineEls.push(el);
        }
        blk.appendChild(el);
        return el;
      };

      for (const [label, res] of CHECKS) {
        addLine((el) => {
          const left = document.createElement("span");
          left.className = "bm";
          left.textContent = label + " " + ".".repeat(24 - label.length) + " ";
          const right = document.createElement("span");
          // safed weapons are not a success state — the joke reads flat
          right.className = res === "SAFE" ? "bm" : "bok";
          right.textContent = "[" + res + "]";
          el.append(left, right);
        });
      }
      addLine(null); // spacer row, permanent blank
      addLine((el) => (el.textContent = "ALL SYSTEMS NOMINAL"));
      addLine((el) => {
        el.textContent = "SYSTEM READY";
        const cur = document.createElement("span");
        cur.className = "cur";
        el.appendChild(cur);
      });

      const skipHint = document.createElement("div");
      skipHint.className = "bskip";
      skipHint.textContent = matchMedia("(pointer: coarse)").matches
        ? "TAP TO SKIP"
        : "PRESS ANY KEY";

      overlay.append(blk, skipHint);
      document.head.appendChild(style);
      document.body.appendChild(overlay);
      document.documentElement.style.overflow = "hidden";

      const timers = [];
      const at = (ms, fn) => timers.push(setTimeout(fn, ms));
      let done = false;
      const exit = (fast) => {
        if (done) return;
        done = true;
        timers.forEach(clearTimeout);
        removeEventListener("keydown", onSkip, true);
        removeEventListener("pointerdown", onSkip, true);
        removeEventListener("touchstart", onSkip, true);
        if (fast) overlay.classList.add("fast");
        overlay.classList.add("out");
        setTimeout(
          () => {
            overlay.remove();
            style.remove();
            document.documentElement.style.overflow = "";
          },
          fast ? 150 : 250,
        );
      };
      const onSkip = () => exit(true);
      addEventListener("keydown", onSkip, true);
      addEventListener("pointerdown", onSkip, true);
      addEventListener("touchstart", onSkip, true);

      // header in at 120ms, lines whole per 170ms tick, long hold so the
      // copy can actually be read, fade — ≈3.1s total, still skippable
      at(0, () => ident.classList.add("in"));
      let t = 120;
      for (const el of lineEls) {
        t += 170;
        at(t, () => el.classList.add("in"));
      }
      at(t + 900, () => exit(false));
    })();
  </script>
  <div class="container">
    <header class="hero">
      <HeroGridGlow />
      <div class="hero-main">
        <p class="label-xs hero-hello">
          <span class="hello-chevrons" aria-hidden="true">›››</span> HI, I'M
        </p>
        <h1 class="display-mono hero-title">{SITE.name.toUpperCase()}</h1>
        <p class="hero-subtitle">{SITE.subtitle}</p>
        <ul class="hero-roles" role="list">
          {SITE.roles.map((r) => <li class="hero-role">{r}</li>)}
        </ul>
        <p class="serial hero-serial">
          {SITE.serial}
          <span class="barcode decal-md" aria-hidden="true"></span>
        </p>
      </div>
      <div class="hero-side decal-md">
        <dl class="spec-readout value-s">
          <div><dt>UNIT</dt><dd>{SITE.ident}</dd></div>
          <div><dt>TYPE</dt><dd>PERSONAL TERMINAL</dd></div>
          <div><dt>STATUS</dt><dd class="ok">● ACTIVE</dd></div>
          <div><dt>BUILD</dt><dd>{SITE.year}.07</dd></div>
        </dl>
        <div class="dot-grid" aria-hidden="true"></div>
      </div>
    </header>

    <section class="home-section">
      <Kicker label="RECENT / POSTS" moreHref="/posts" moreLabel="ALL POSTS" />
      <ul class="card-grid" role="list">
        {
          posts.slice(0, 3).map((p, i) => (
            <li>
              <Card
                href={`/posts/${p.id}`}
                eyebrow={p.data.category}
                title={p.data.title}
                excerpt={p.data.description}
                meta={`${fmt(p.data.date)} · ${p.data.readTime} · ${tagStr(p.data.tags)}`}
                index={i + 1}
              />
            </li>
          ))
        }
      </ul>
    </section>

    {
      projects.length > 0 && (
        <section class="home-section">
          <Kicker label="RECENT / PROJECTS" moreHref="/projects" moreLabel="ALL PROJECTS" />
          <ul class="card-grid" role="list">
            {projects.slice(0, 3).map((p, i) => (
              <li>
                <Card
                  href={`/projects/${p.id}`}
                  eyebrow="PROJECT"
                  title={p.data.title}
                  excerpt={p.data.description}
                  meta={`${fmt(p.data.date)} · ${tagStr(p.data.tags)}`}
                  status={p.data.status}
                  statusTone={STATUS_TONE[p.data.status]}
                  index={i + 1}
                />
              </li>
            ))}
          </ul>
        </section>
      )
    }
  </div>
</BaseLayout>

<style>
  .hero {
    position: relative;
    display: flex;
    flex-wrap: wrap;
    align-items: flex-end;
    justify-content: space-between;
    gap: var(--sp-5);
    padding: var(--sp-7) 0 var(--sp-6);
    margin-bottom: var(--sp-7);
    border-bottom: 1px solid var(--border);
  }
  /* hero content rides above the glow canvas */
  .hero-main,
  .hero-side {
    position: relative;
    z-index: 1;
  }
  /* crosshair registration marks, top corners */
  .hero::before,
  .hero::after {
    content: "+";
    position: absolute;
    top: var(--sp-4);
    z-index: 1;
    font: 400 var(--fs-value-s) / 1 var(--font-mono);
    color: var(--text-disabled);
  }
  .hero::before {
    left: 0;
  }
  .hero::after {
    right: 0;
  }

  .hero-hello {
    color: var(--text-muted);
    margin: 0 0 var(--sp-3);
  }
  .hello-chevrons {
    color: var(--link);
    letter-spacing: 0.1em;
  }
  /* a notch under the full display size — the descriptor carries the intro */
  .hero-title {
    font-size: clamp(2rem, 1.3rem + 3.2vw, 3rem);
    margin: 0 0 var(--sp-3);
  }
  .hero-subtitle {
    font: 400 var(--fs-body-m) / 1.5 var(--font-sans);
    color: var(--text);
    margin: 0 0 var(--sp-4);
  }
  /* the operator's trades, promoted from subtext to labelled plates */
  .hero-roles {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
    list-style: none;
    margin: 0 0 var(--sp-4);
    padding: 0;
  }
  .hero-role {
    font: 500 var(--fs-value-s) / 1 var(--font-mono);
    letter-spacing: var(--track-label);
    color: var(--text);
    border: 1px solid var(--border);
    border-left: 2px solid var(--accent);
    background: var(--surface);
    padding: var(--sp-2) var(--sp-3);
  }
  .hero-serial {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    margin: 0;
  }

  .hero-side {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: var(--sp-3);
  }
  /* scoped display:flex outranks the global .decal-md hide — repeat it */
  @media (max-width: 767px) {
    .hero-side {
      display: none;
    }
  }
  .spec-readout {
    font-family: var(--font-mono);
    min-width: 240px;
    margin: 0;
    padding: var(--sp-4);
    border: 1px solid var(--border);
    background: var(--surface);
    position: relative;
  }
  /* the one purple hint on the readout — corner tick, not a fill */
  .spec-readout::before {
    content: "";
    position: absolute;
    top: -5px;
    left: -5px;
    width: 10px;
    height: 10px;
    border-top: 2px solid var(--accent);
    border-left: 2px solid var(--accent);
  }
  .spec-readout::after {
    content: "";
    position: absolute;
    bottom: -5px;
    right: -5px;
    width: 10px;
    height: 10px;
    border-bottom: 1px solid var(--border-active);
    border-right: 1px solid var(--border-active);
  }
  .spec-readout div {
    display: flex;
    justify-content: space-between;
    gap: var(--sp-5);
  }
  .spec-readout div + div {
    margin-top: var(--sp-2);
  }
  .spec-readout dt {
    color: var(--text-muted);
  }
  .spec-readout dd {
    margin: 0;
  }
  .spec-readout .ok {
    color: var(--ok-text);
  }

  .home-section {
    margin-bottom: var(--sp-7);
  }
</style>
