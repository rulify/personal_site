---
import BaseLayout from "../layouts/BaseLayout.astro";
import { JP } from "../consts";
---

<BaseLayout title="404" description="No such route.">
  <div class="container">
    <div class="notfound">
      <p class="label-xs code">
        <span aria-hidden="true">✳</span> ERR / 404
      </p>
      <h1 class="display-mono">
        NO SUCH ROUTE <span class="jp decal-md" aria-hidden="true">{JP.notFound}</span>
      </h1>
      <p class="value-s detail">The requested path does not resolve.</p>
      <div class="hazard-strip nf-strip" aria-hidden="true"></div>
      <a class="label-xs home" href="/">RETURN /</a>
    </div>
  </div>
</BaseLayout>

<style>
  .notfound {
    max-width: var(--measure);
    margin: var(--sp-8) auto;
  }
  .code {
    color: var(--error-text);
    margin: 0 0 var(--sp-3);
  }
  .notfound h1 {
    margin-bottom: var(--sp-3);
  }
  .notfound h1 .jp {
    font-size: 0.4em;
    vertical-align: 0.5em;
    letter-spacing: 0.3em;
  }
  .detail {
    color: var(--text-muted);
    margin: 0 0 var(--sp-4);
  }
  .nf-strip {
    max-width: 240px;
    margin-bottom: var(--sp-6);
  }
  .home {
    display: inline-block;
    color: var(--text-muted);
    border: 1px solid var(--border);
    border-radius: var(--radius-s);
    padding: var(--sp-2) var(--sp-3);
    text-decoration: none;
    transition:
      color var(--transition),
      border-color var(--transition);
  }
  .home:hover,
  .home:focus-visible {
    color: var(--text);
    border-color: var(--border-active);
  }
</style>
