---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="404" description="No such route." noindex>
  <div class="container">
    <div class="notfound">
      <p class="label-xs code">
        <span aria-hidden="true">✳</span> ERR / 404
      </p>
      <h1 class="display-mono">NO SUCH ROUTE</h1>
      <p class="value-s detail">The requested path does not resolve.</p>
      <div class="hazard-strip nf-strip" aria-hidden="true"></div>
      <a class="label-xs home" href="/">RETURN HOME</a>
    </div>
  </div>
</BaseLayout>

<style>
  .notfound {
    font-size: var(--fs-body-m);
    max-width: var(--measure);
    margin: var(--sp-8) auto;
  }
  .code {
    color: var(--error-text);
    margin: 0 0 var(--sp-3);
  }
  .notfound h1 {
    margin-bottom: var(--sp-3);
  }
  .detail {
    color: var(--text-muted);
    margin: 0 0 var(--sp-4);
  }
  /* genuine error state, so the strip may carry the hazard colour (§3) */
  .nf-strip {
    max-width: 240px;
    margin-bottom: var(--sp-6);
    background: repeating-linear-gradient(
      -45deg,
      var(--error) 0 6px,
      transparent 6px 14px
    );
  }
  .home {
    display: inline-block;
    color: var(--text-muted);
    border: 1px solid var(--border);
    border-radius: var(--radius-s);
    padding: var(--sp-2) var(--sp-3);
    text-decoration: none;
    transition:
      color var(--transition),
      border-color var(--transition);
  }
  .home:hover,
  .home:focus-visible {
    color: var(--text);
    border-color: var(--border-active);
  }
</style>
